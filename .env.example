# Copy this to .env and fill in the values

# Shared password for the dashboard (no user accounts)
PASSWORD=change_me_please

# Anthropic API key for AI insights
ANTHROPIC_API_KEY=sk-ant-...

# Express session secret — generate a random string, e.g.: openssl rand -hex 32
SESSION_SECRET=change_this_to_a_random_secret

# Port the Node process listens on (nginx will proxy to this)
PORT=3000
